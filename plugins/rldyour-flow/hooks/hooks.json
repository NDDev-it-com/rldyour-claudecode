{
  "$schema": "../../../config/schemas/hooks.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session_start_worktree_bootstrap.sh"],
            "timeout": 30,
            "statusMessage": "Checking worktree agent-only bootstrap"
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session_start_context.sh"],
            "timeout": 5,
            "statusMessage": "Loading rldyour-flow session context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use_commit_advice.sh"],
            "timeout": 5,
            "statusMessage": "Checking rldyour commit advice"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/stop_post_task_sync.sh"],
            "timeout": 10,
            "statusMessage": "Checking rldyour-flow post-task sync"
          }
        ]
      }
    ]
  }
}
