{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "serena-agent==1.2.0",
        "--python", "3.13",
        "--prerelease", "allow",
        "serena", "start-mcp-server",
        "--project-from-cwd",
        "--context=agent",
        "--enable-web-dashboard", "False",
        "--open-web-dashboard", "False"
      ],
      "alwaysLoad": true
    },
    "sequential-thinking": {
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ],
      "env": {
        "DISABLE_THOUGHT_LOGGING": "true"
      }
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@0.0.75",
        "--headless",
        "--caps=network,storage,testing,devtools"
      ]
    },
    "chrome-devtools": {
      "command": "bunx",
      "args": [
        "chrome-devtools-mcp@0.25.0",
        "--headless",
        "--isolated",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    },
    "context7": {
      "command": "bunx",
      "args": [
        "@upstash/context7-mcp@2.2.5"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "semgrep": {
      "command": "uvx",
      "args": [
        "--from", "semgrep==1.162.0",
        "semgrep", "mcp"
      ]
    },
    "shadcn": {
      "command": "bunx",
      "args": [
        "shadcn@4.7.0",
        "mcp"
      ]
    },
    "dart-flutter": {
      "command": "dart",
      "args": [
        "mcp-server",
        "--force-roots-fallback"
      ]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "openai-docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
