# OS
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# Logs
*.log
logs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.python-version
.venv/
venv/
# uv lock is generated from pyproject.toml at install time. This marketplace
# is metadata-only (no Python package built); uv.lock has no reproducibility
# value and would otherwise block `fullrepo_sync.py --publish` as untracked.
uv.lock

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Bun
bun.lockb

# Serena runtime markers (per fullrepo policy)
.serena/cache/
.serena/.gitignore
.serena/project.local.yml
.serena/.sync_marker
.serena/.serena_sync_state.json
.serena/.auto_sync_head
.serena/.active_workflow_intent.json
.serena/.dirty_stop_ack
.serena/.flow_sync_marker
.serena/.flow_post_task_state.json
.serena/.stop_lifecycle_timeout_marker
.serena/diagnostics/
.serena/reviews/

# Claude Code local-only
.claude/settings.local.json

# Browser / Webwright / Playwright CLI runtime artifacts
browser/**
!browser/
!browser/.gitkeep
.playwright-cli/
playwright-report/
test-results/
.webwright-runs/
outputs/webwright/
final_runs/
**/final_script_log.txt
**/trajectory.json
**/raw_responses.jsonl
**/screenshots/*.png
**/screenshots/*.jpg
**/screenshots/*.jpeg
**/screenshots/*.webp
