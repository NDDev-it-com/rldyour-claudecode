{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nddev-it-com/rldyour-claudecode/blob/main/config/schemas/marketplace.json",
  "title": "Claude Code Plugin Marketplace Manifest",
  "description": "Validates .claude-plugin/marketplace.json against the rldyour-claudecode contract. Tracks Claude Code canonical fields plus repo-specific invariants.",
  "type": "object",
  "required": ["name", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "kebab-case marketplace slug"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pluginRoot": {
          "type": "string",
          "description": "Optional shortcut prefix for plugin source paths. Anthropic plugins-official does not use this field; rldyour-claudecode also avoids it (sources stay as './plugins/<name>') so install path resolution is unambiguous."
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "source": {
            "type": "string",
            "description": "Path relative to the marketplace root (e.g. './plugins/rldyour-mcps')."
          },
          "description": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
            "description": "Semantic Version (SemVer 2.0.0)."
          },
          "author": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": { "name": { "type": "string" } }
          },
          "category": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "license": { "type": "string" }
        }
      }
    }
  }
}
