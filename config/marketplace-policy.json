{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_description": "Centralized rldyour-claudecode marketplace invariants. Read by validate_marketplace.sh + future validate_boundaries.py. When you add a new plugin or change ownership boundaries, update this file in the same commit.",
  "verified_on": "2026-05-23",
  "mcp_owner": "rldyour-mcps",
  "hook_owners": ["rldyour-flow", "rldyour-serena-mcp"],
  "lsp_owner": "rldyour-lsps",
  "skills_only_plugins": [
    "rldyour-browser",
    "rldyour-design",
    "rldyour-lsps",
    "rldyour-security",
    "rldyour-rules"
  ],
  "plugin_dependencies": {
    "rldyour-mcps": [],
    "rldyour-serena-mcp": ["rldyour-mcps"],
    "rldyour-flow": ["rldyour-mcps", "rldyour-serena-mcp"],
    "rldyour-explore": ["rldyour-mcps"],
    "rldyour-security": ["rldyour-mcps"],
    "rldyour-browser": ["rldyour-mcps"],
    "rldyour-design": ["rldyour-mcps", "rldyour-browser"],
    "rldyour-lsps": ["rldyour-mcps"],
    "rldyour-rules": ["rldyour-mcps"]
  },
  "protected_branches": [
    "main",
    "master",
    "develop",
    "development",
    "staging",
    "production",
    "prod",
    "fullrepo"
  ],
  "fullrepo_branch": "fullrepo",
  "agent_only_path_globs": [
    "AGENTS.md",
    "CLAUDE.md",
    "REVIEW.md",
    "GEMINI.md",
    "QWEN.md",
    ".cursorrules",
    ".windsurfrules",
    ".claude/**",
    ".cursor/rules/**",
    ".gemini/**",
    ".roo/**",
    ".windsurf/**",
    ".openhands/**",
    ".aider*",
    ".codex/**",
    ".agents/skills/**",
    ".agents/commands/**",
    ".agents/hooks/**",
    ".github/copilot-instructions.md",
    ".github/instructions/**",
    ".github/prompts/**",
    ".serena/project.yml",
    ".serena/memories/**",
    ".serena/plans/**",
    ".serena/research/**",
    ".serena/newproj/**",
    ".serena/deploy/**"
  ],
  "runtime_exclude_globs": [
    ".serena/cache/**",
    ".serena/diagnostics/**",
    ".serena/reviews/**",
    ".serena/.gitignore",
    ".serena/project.local.yml",
    ".serena/.sync_marker",
    ".serena/.flow_sync_marker",
    ".serena/.serena_sync_state.json",
    ".serena/.auto_sync_head",
    ".serena/.active_workflow_intent.json",
    ".serena/.dirty_stop_ack",
    ".serena/.flow_post_task_state.json",
    ".serena/.bootstrap_overrides.log"
  ],
  "skill_listing_budget_fraction": 0.04,
  "max_skill_description_chars": 1536,
  "claude_code_min_version": "2.1.150",
  "tag_conventions": {
    "marketplace": "marketplace--v<X.Y.Z>",
    "plugin": "<plugin-name>--v<X.Y.Z>"
  },
  "reviewer_transport_marker": "RLDYOUR_REPORT_EOF",
  "reviewer_report_dir_template": ".serena/reviews/<run_id>/",
  "reviewer_run_id_format": "<UTC-ISO-compact>-<git-short-sha>"
}
