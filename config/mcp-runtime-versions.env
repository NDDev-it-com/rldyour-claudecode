# Pinned runtime package versions for reproducible MCP startup.
# Source of truth: plugins/rldyour-mcps/.mcp.json
# Update intentionally after validating MCP capability smoke for the affected server.
#
# scripts/check_mcp_runtime_versions.py compares these pins against the live
# .mcp.json and surfaces any drift. CI dependency-check.yml runs the same
# check on a schedule and probes upstream registries for newer releases.

# Claude Code CLI minimum version. Floor matches package.json CI pin.
# Covers all features used by this repo: opus[1m] syntax (v2.1.111+, account-gated),
# alwaysLoad MCP option (v2.1.121+), claude plugin tag (v2.1.118+), hook `if` filter
# (v2.1.118+), maxSkillDescriptionChars/skillListingBudgetFraction (v2.1.105+),
# skillOverrides (v2.1.129+, plugin skills exempt), experimental.{themes,monitors} (v2.1.129+).
CLAUDE_CODE_MIN_VERSION=2.1.146

# Stdio MCP servers (uvx + bunx + system binaries).
SERENA_AGENT_VERSION=1.5.1
SEQUENTIAL_THINKING_MCP_VERSION=2025.12.18
PLAYWRIGHT_MCP_VERSION=0.0.75
CHROME_DEVTOOLS_MCP_VERSION=1.0.1
CONTEXT7_MCP_VERSION=2.2.5
SEMGREP_VERSION=1.163.0
SHADCN_VERSION=4.8.0

# HTTP MCP servers (no version pin - pinned by URL only).
DEEPWIKI_MCP_URL=https://mcp.deepwiki.com/mcp
GREP_MCP_URL=https://mcp.grep.app
FIGMA_MCP_URL=https://mcp.figma.com/mcp
OPENAI_DOCS_MCP_URL=https://developers.openai.com/mcp

# System binaries - pinned by host toolchain (Homebrew bottle / system installer / Dart SDK).
# Probed at runtime via `<binary> --version`; parity enforced by check_mcp_runtime_versions.py.
#   github: requires `github-mcp-server` on PATH (e.g. `brew install github-mcp-server`).
#           Uses `github-mcp-server stdio` (replaces Copilot-gated HTTP endpoint).
#   dart-flutter: requires `dart` (Dart/Flutter SDK) on PATH; uses `dart mcp-server`.
#                 MCP server ships inside the Dart SDK; pin is the Dart SDK version.
# Dart SDK 3.12.0 is the latest stable on 2026-05-20 (verified via
# storage.googleapis.com/dart-archive/channels/stable/release/latest).
# Pin stays at 3.11.0 because the local toolchain reports 3.11.0; bumping
# the pin without upgrading the host binary creates drift the checker
# rejects. To upgrade: `brew upgrade dart` then bump this value + the
# scripts/probe_mcp_upstream.py PROBES tuple.
GITHUB_MCP_SERVER_VERSION=1.0.5
DART_SDK_VERSION=3.11.0
